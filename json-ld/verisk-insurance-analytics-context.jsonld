    "ConstructionData": "verisk:ConstructionData",
    "PerilScoreResponse": "verisk:PerilScoreResponse",
    "RiskScoreRequest": "verisk:RiskScoreRequest",
    "ClaimsBenchmarks": "verisk:ClaimsBenchmarks",
    "PropertyLookupResponse": "verisk:PropertyLookupResponse",
    "RiskScoreResponse": "verisk:RiskScoreResponse",
    "street": {
      "@id": "verisk:street",
      "@type": "xsd:string"
    },
    "city": {
      "@id": "verisk:city",
      "@type": "xsd:string"
    },
    "state": {
      "@id": "verisk:state",
