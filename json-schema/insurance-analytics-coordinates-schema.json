{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/verisk/refs/heads/main/json-schema/insurance-analytics-coordinates-schema.json",
  "title": "Coordinates",
  "description": "Coordinates schema from Verisk Insurance Analytics API",
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "example": 36.1699
    },
    "longitude": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "example": -115.1398
    }
  }
}